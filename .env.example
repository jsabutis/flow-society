# Local dev (SQLite). For Vercel + Neon Postgres, set DATABASE_URL to your
# Neon connection string and switch the prisma `provider` to "postgresql".
DATABASE_URL="file:./dev.db"

# Admin gate. Visit /admin?token=YOUR_TOKEN to manage tours, departures, bookings.
ADMIN_TOKEN="changeme-local-dev-token"

# Optional. If unset, emails are logged to the console instead of sent.
RESEND_API_KEY=""
RESEND_FROM="bookings@example.com"
ADMIN_NOTIFY_EMAIL="you@example.com"
