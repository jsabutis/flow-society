# PostgreSQL (required). Use Neon (free), Vercel Storage → Neon, or local Postgres, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flow_society"

# Admin gate. Visit /admin?token=YOUR_TOKEN to manage tours, departures, bookings.
ADMIN_TOKEN="changeme-local-dev-token"

# Optional. If unset, emails are logged to the console instead of being sent.
RESEND_API_KEY=""
RESEND_FROM="bookings@example.com"
ADMIN_NOTIFY_EMAIL="you@example.com"
